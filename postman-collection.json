{
  "info": {
    "name": "Room Booking System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [{ "key": "base_url", "value": "http://localhost:5000/api" }],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@test.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Rooms",
      "item": [
        {
          "name": "Get All Rooms",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/rooms"
          }
        },
        {
          "name": "Get Room By ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/rooms/1"
          }
        },
        {
          "name": "Check Availability",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/rooms/1/availability?startDate=2026-04-01&endDate=2026-04-05",
              "query": [
                { "key": "startDate", "value": "2026-04-01" },
                { "key": "endDate", "value": "2026-04-05" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/bookings",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roomId\": 1,\n  \"startDate\": \"2026-04-01\",\n  \"endDate\": \"2026-04-05\"\n}"
            }
          }
        },
        {
          "name": "Create Booking — Overlap (should return 409)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/bookings",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roomId\": 1,\n  \"startDate\": \"2026-04-03\",\n  \"endDate\": \"2026-04-07\"\n}"
            }
          }
        },
        {
          "name": "Get My Bookings",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/bookings/my"
          }
        },
        {
          "name": "Get Booking By ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/bookings/1"
          }
        }
      ]
    }
  ]
}
